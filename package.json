{
  "name": "dbsource",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003 -H 127.0.0.1",
    "dev:mobile": "next dev -p 3003 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3003 -H 127.0.0.1",
    "preview": "npm run rebuild && npm run start",
    "preview:safe": "node scripts/kill-port.mjs 3003 && npm run rebuild && npm run start",
    "preview:quick": "next start -p 3003 -H 127.0.0.1",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "rebuild": "npm run clean && npm run build",
    "lint": "next lint",
    "doctor": "npm run rebuild && npm run lint",
    "sync:case-images": "python scripts/sync-case-images.py",
    "sync:product-images": "python scripts/sync-product-images.py",
    "sync:product-images:strapi": "node scripts/sync-product-images-to-strapi.mjs",
    "sync:product-images:all": "npm run sync:product-images && npm run sync:product-images:strapi",
    "docs:ppt": "node scripts/generate-project-report-ppt.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^11.18.2",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "next": "14.2.28",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-intersection-observer": "^10.0.3",
    "schema-dts": "^2.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.28",
    "postcss": "^8",
    "pptxgenjs": "^4.0.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
