# 网站地址（SEO / OG / sitemap）
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3003

# Strapi CMS
CMS_URL=http://localhost:1337
NEXT_PUBLIC_CMS_URL=http://localhost:1337
NEXT_PUBLIC_USE_MOCK_DATA=false

# Strapi 管理 Token（仅服务端，用于后台读取询盘等私有数据）
# 在 Strapi 后台 Settings → API Tokens 创建 Full access 或自定义 Token
STRAPI_API_TOKEN=

# 简易后台口令（可选，留空则本地免登录）
ADMIN_TOKEN=

# 询盘 webhook（可选，企业微信/钉钉机器人 URL）
LEAD_WEBHOOK_URL=

# 访问统计（可选，填入 GA4 测量 ID，如 G-XXXXXXXX）
NEXT_PUBLIC_GA_ID=

# DeepSeek AI（智能顾问 /api/ai/chat）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_DAILY_LIMIT=20
AI_CACHE_TTL_HOURS=24
